{
  "name": "spectatty",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for headless terminal emulation — spawn PTY sessions, send keystrokes, capture screenshots",
  "license": "MIT",
  "keywords": ["mcp", "terminal", "pty", "headless", "xterm", "model-context-protocol"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dayvidwang/spectatty.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "spectatty": "src/cli.ts"
  },
  "files": [
    "src/cli.ts",
    "src/server.ts",
    "src/protocol.ts",
    "src/cast-tail.ts",
    "src/terminal.ts",
    "src/renderer.ts",
    "src/pty.ts",
    "src/runtime.ts",
    "src/themes.ts",
    "src/cast-parser.ts",
    "src/frame-generator.ts",
    "src/to-gif.ts",
    "src/to-mp4.ts",
    "src/tape.ts",
    "src/daemon.ts",
    "src/client.ts",
    "assets/JetBrainsMono-Regular.ttf",
    "assets/JetBrainsMono-Bold.ttf",
    "assets/JetBrainsMono-Italic.ttf",
    "assets/JetBrainsMono-BoldItalic.ttf",
    "README.md"
  ],
  "scripts": {
    "start": "bun src/cli.ts mcp",
    "dev": "bun --watch src/cli.ts mcp",
    "test": "bun vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@napi-rs/canvas": "^0.1.94",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.8",
    "citty": "^0.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "vitest": "^3.0.0"
  }
}
